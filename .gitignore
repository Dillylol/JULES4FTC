# ==========================================
# JULES4FTC Shield - General & Sensitive Docs
# ==========================================
# Blocks the JULES architecture or any future CAD/PDF exports
*.pdf
*.docx
*.pptx
*.xlsx
*.zip
*.tar.gz

# ==========================================
# FTC / Android / Java Essentials
# ==========================================
# Built application files
*.apk
*.aar
*.ap_
*.aab
!libs/*.aar

# Files for the ART/Dalvik VM
*.dex

# Java/JDK files
*.class
*.hprof

# Generated files
bin/
gen/
out/
build/
.gradle/
.externalNativeBuild
.cxx/

# Local configuration files
local.properties
vcs.xml
# Always ignore the keystore if you start signing releases
*.jks
*.keystore

# ==========================================
# IDEs & System Files
# ==========================================
# IntelliJ / Android Studio
*.iml
*.iws
.idea/
# Ignore workspace.xml specifically as it changes constantly and causes merge conflicts
.idea/workspace.xml

# VS Code (if anyone on the team uses it)
.vscode/

# Mac & Windows system bloat
.DS_Store
Thumbs.db

# ==========================================
# AI / Project JULES Specifics
# ==========================================
# If you start training local models or using Python for the autonomous bridge
__pycache__/
*.py[cod]
*$py.class
.env
venv/
env/